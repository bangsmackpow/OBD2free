{
  "name": "OBD2Free",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace OBD2Free.xcworkspace -scheme OBD2Free -configuration Release",
    "build:web": "cd web && npm run build",
    "build:worker": "cd cloudflare/worker && npm run build:worker",
    "deploy:worker": "cd cloudflare/worker && wrangler deploy",
    "deploy:web": "wrangler pages deploy web/dist --project-name obd2free-web"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/stack": "^6.3.28",
    "react": "18.2.0",
    "react-native": "0.73.4",
    "react-native-background-fetch": "^4.1.9",
    "react-native-ble-plx": "^3.5.1",
    "react-native-foreground-service": "^1.0.0",
    "react-native-fs": "^2.20.0",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "^2.16.2",
    "react-native-mmkv": "^2.12.2",
    "react-native-permissions": "^3.10.1",
    "react-native-reanimated": "^3.6.2",
    "react-native-safe-area-context": "^4.10.5",
    "react-native-screens": "^3.29.0",
    "react-native-svg": "^14.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/runtime": "^7.23.0",
    "@react-native/babel-preset": "0.73.19",
    "@react-native/eslint-config": "0.73.2",
    "@react-native/metro-config": "0.73.3",
    "@react-native/typescript-config": "0.73.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "babel-jest": "^29.6.0",
    "eslint": "^8.57.0",
    "jest": "^29.6.0",
    "metro-react-native-babel-preset": "0.77.0",
    "prettier": "3.1.0",
    "typescript": "5.1.3"
  }
}
